# ── Neon PostgreSQL ──────────────────────────────────────────
DATABASE_URL="postgresql://user:password@host-pooler.region.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://user:password@host.region.neon.tech/neondb?sslmode=require"

# ── Clerk Auth ───────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."
CLERK_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/login"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/login"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/dashboard"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/dashboard"

# ── Claude AI (default LLM provider) ────────────────────────
ANTHROPIC_API_KEY="sk-ant-..."

# ── LLM Provider (Feature: multi-model support) ──────────────
# Options: 'claude' (default) | 'ollama' | 'huggingface'
LLM_PROVIDER="claude"

# Ollama (local development)
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="llama3"

# HuggingFace (production open-source)
HUGGINGFACE_KEY="hf_..."
HF_MODEL="mistralai/Mixtral-8x7B-Instruct-v0.1"
HF_MODERATION_MODEL="microsoft/Phi-3-mini-4k-instruct"
HF_EMBEDDING_MODEL="sentence-transformers/all-MiniLM-L6-v2"

# ── Agent Config ──────────────────────────────────────────────
# Name used for @mention in group chat
AGENT_NAME="researchbot"

# ── Web Search (Feature 2 — optional) ────────────────────────
# Leave empty to use DuckDuckGo (free, no key)
SERPAPI_KEY=""

# ── Semantic Scholar (optional — higher rate limits) ─────────
SEMANTIC_SCHOLAR_API_KEY=""

# ── Uploadthing (file uploads) ───────────────────────────────
UPLOADTHING_SECRET="sk_live_..."
UPLOADTHING_APP_ID="..."

# ── Firebase Realtime Chat ────────────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY="AIza..."
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="your-project.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="your-project-id"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="your-project.firebasestorage.app"
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID="..."
NEXT_PUBLIC_FIREBASE_APP_ID="1:...:web:..."

# Model routing (DeepSeek via Ollama or HuggingFace)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_LATEX_MODEL=deepseek-v3
OLLAMA_REASONING_MODEL=deepseek-r1
HF_API_KEY=hf_xxxx
HF_MODEL=deepseek-ai/DeepSeek-V3
HF_REASONING_MODEL=deepseek-ai/DeepSeek-R1
HF_EQUATION_MODEL=linxy/LaTeX-OCR
HF_TABLE_OCR_MODEL=ucaslcl/GOT-OCR2_0
HF_VISION_MODEL=OpenGVLab/InternVL2-8B

# Equation OCR
PIX2TEX_API_URL=https://your-space.hf.space

# LaTeX compilation
LATEX_COMPILE_URL=https://latexonline.cc/compile

# Google Classroom
GOOGLE_CLIENT_ID=xxx
GOOGLE_CLIENT_SECRET=xxx
NEXT_PUBLIC_URL=https://your-app.vercel.app
